# MiniMax M2.7 API Configuration (Anthropic-compatible)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.minimax.chat/v1
ANTHROPIC_MODEL=MiniMax-M2.7-highspeed

# Optional: Override model per agent
# ANTHROPIC_MODEL_WRITER=MiniMax-M2.7-highspeed
# ANTHROPIC_MODEL_REVIEWER=MiniMax-M2.7-highspeed

# Semantic Scholar API Key (optional — increases rate limit from IP-level to key-level)
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTICSCHOLAR_API_KEY=your_s2_api_key_here
